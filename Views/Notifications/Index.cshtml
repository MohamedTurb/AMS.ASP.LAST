@model List<Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="container">
    @{
        ViewBag.Subtitle = "Stay updated with system notifications";
        ViewBag.Actions = $@"<button onclick=""markAllRead()"" class=""btn btn-outline"">
            <i class=""fas fa-check-double""></i>
            Mark All Read
        </button>";
    }
    @await Html.PartialAsync("_PageHeader", "Notifications")

    @if (Model?.Count > 0)
    {
        <div class="data-list">
            @foreach (var notification in Model.OrderByDescending(n => n.CreatedAt))
            {
                <div class="data-list-item" style="cursor: pointer;" onclick="openNotification('@notification.Link')">
                    <div class="data-list-item-content">
                        <div class="data-list-item-title">
                            @if (!notification.IsRead)
                            {
                                <span style="width: 8px; height: 8px; background-color: var(--color-primary); border-radius: 50%; display: inline-block; margin-right: var(--spacing-2);"></span>
                            }
                            @notification.Message
                        </div>
                        <div class="data-list-item-description">
                            @notification.CreatedAt.ToString("MMM dd, yyyy h:mm tt")
                        </div>
                    </div>
                    <div class="data-list-item-meta">
                        @if (!notification.IsRead)
                        {
                            <span class="badge badge-primary">New</span>
                        }
                        <button type="button" class="btn btn-sm btn-ghost" onclick="markAsRead(@notification.Id, event)">
                            <i class="fas fa-check"></i>
                        </button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state" style="padding: var(--spacing-12) var(--spacing-6);">
            <div class="empty-state-icon"><i class="fas fa-bell-slash"></i></div>
            <p class="empty-state-title">No notifications</p>
            <p class="empty-state-description">You're all caught up!</p>
        </div>
    }
</div>

@section Scripts {
<script>
    function markAsRead(id, event) {
        event.stopPropagation();
        API.post(`@Url.Action("MarkRead")/${id}`, {}).then(() => {
            window.location.reload();
        });
    }

    function markAllRead() {
        API.post(`@Url.Action("MarkAllRead")`, {}).then(() => {
            window.location.reload();
        });
    }

    function openNotification(link) {
        if (link) window.location.href = link;
    }
</script>
}
