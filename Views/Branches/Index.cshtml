@model PaginatedList<Branch>
@{
    ViewData["Title"] = "Branches";
}

<div class="container">
    <!-- Page Header -->
    @{
        ViewBag.Subtitle = "Manage organizational branches and locations";
        ViewBag.Actions = $@"<a href=""{Url.Action("Create", "Branches")}"" class=""btn btn-primary"">
            <i class=""fas fa-plus""></i>
            New Branch
        </a>";
    }
    @await Html.PartialAsync("_PageHeader", "Branches")

    <!-- Search & Filters -->
    <div class="card" style="margin-bottom: var(--spacing-6);">
        <div class="card-body">
            <form method="get" asp-action="Index" class="search-filters">
                <div class="search-box">
                    <input type="text" name="searchString" class="form-input" placeholder="Search by name, city, phone..." value="@ViewContext.HttpContext.Request.Query["searchString"]" />
                    <i class="fas fa-search search-box-icon"></i>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-filter"></i>
                    Search
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline">
                    <i class="fas fa-redo"></i>
                    Reset
                </a>
            </form>
        </div>
    </div>

    <!-- Branches Grid -->
    <div class="row">
        @if (Model?.Count > 0)
        {
            @foreach (var branch in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card" style="height: 100%; cursor: pointer;" onclick="window.location.href='@Url.Action("Details", new { id = branch.Id })';">
                        <div class="card-body">
                            <!-- Branch Icon/Header -->
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--spacing-4);">
                                <div>
                                    <h5 style="margin: 0; font-size: var(--font-size-lg); font-weight: bold;">
                                        @branch.Name
                                    </h5>
                                    <p style="margin: var(--spacing-1) 0 0 0; color: var(--color-text-muted); font-size: var(--font-size-sm);">
                                        Branch
                                    </p>
                                </div>
                                <div style="font-size: 2rem; color: var(--color-primary); opacity: 0.5;">
                                    <i class="fas fa-building"></i>
                                </div>
                            </div>

                            <!-- Branch Info -->
                            <div style="display: flex; flex-direction: column; gap: var(--spacing-3); margin-bottom: var(--spacing-4); border-bottom: 1px solid var(--color-border); padding-bottom: var(--spacing-4);">
                                <div style="display: flex; align-items: flex-start; gap: var(--spacing-2); font-size: var(--font-size-sm);">
                                    <i class="fas fa-map-marker-alt" style="color: var(--color-primary); margin-top: 2px;"></i>
                                    <div>@branch.Address</div>
                                </div>

                                <div style="display: flex; align-items: center; gap: var(--spacing-2); font-size: var(--font-size-sm);">
                                    <i class="fas fa-phone" style="color: var(--color-primary);"></i>
                                    <a href="tel:@branch.Phone">@branch.Phone</a>
                                </div>
                            </div>

                            <!-- Statistics -->
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--spacing-3); margin-bottom: var(--spacing-4);">
                                <div>
                                    <p style="margin: 0; font-size: var(--font-size-xs); color: var(--color-text-muted); text-transform: uppercase;">Staff</p>
                                    <p style="margin: var(--spacing-1) 0 0 0; font-size: var(--font-size-lg); font-weight: bold;">@(branch.Users?.Count ?? 0)</p>
                                </div>
                                <div>
                                    <p style="margin: 0; font-size: var(--font-size-xs); color: var(--color-text-muted); text-transform: uppercase;">Beneficiaries</p>
                                    <p style="margin: var(--spacing-1) 0 0 0; font-size: var(--font-size-lg); font-weight: bold;">@(branch.Beneficiaries?.Count ?? 0)</p>
                                </div>
                            </div>

                            <!-- Actions -->
                            <div class="btn-group" style="width: 100%; gap: var(--spacing-2);">
                                <a href="@Url.Action("Edit", new { id = branch.Id })" class="btn btn-sm btn-outline" style="flex: 1;" onclick="event.stopPropagation();">
                                    <i class="fas fa-edit"></i>
                                    Edit
                                </a>
                                <button type="button" class="btn btn-sm btn-danger" onclick="deleteBranch(@branch.Id, event);">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="empty-state" style="padding: var(--spacing-12) var(--spacing-6);">
                    <div class="empty-state-icon">
                        <i class="fas fa-building"></i>
                    </div>
                    <p class="empty-state-title">No branches found</p>
                    <p class="empty-state-description">
                        Create your first branch to get started with branch management.
                    </p>
                    <a href="@Url.Action("Create")" class="btn btn-primary">
                        <i class="fas fa-plus"></i>
                        Create Branch
                    </a>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model?.TotalPages > 1)
    {
        <div style="display: flex; justify-content: center; margin-top: var(--spacing-8);">
            <nav aria-label="Page navigation">
                <ul class="pagination">
                    @if (Model.HasPreviousPage)
                    {
                        <li>
                            <a href="@Url.Action("Index", new { page = Model.PageIndex - 1 })" class="pagination-item">
                                <i class="fas fa-chevron-left"></i> Previous
                            </a>
                        </li>
                    }

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        @if (i == Model.PageIndex)
                        {
                            <li>
                                <span class="pagination-item active">@i</span>
                            </li>
                        }
                        else if (i <= Model.PageIndex + 2 && i >= Model.PageIndex - 2)
                        {
                            <li>
                                <a href="@Url.Action("Index", new { page = i })" class="pagination-item">@i</a>
                            </li>
                        }
                    }

                    @if (Model.HasNextPage)
                    {
                        <li>
                            <a href="@Url.Action("Index", new { page = Model.PageIndex + 1 })" class="pagination-item">
                                Next <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>

@section Scripts {
<script>
    function deleteBranch(id, event) {
        event.stopPropagation();
        Confirm.show(
            'Are you sure you want to delete this branch? This action cannot be undone.',
            async () => {
                try {
                    const response = await fetch(`@Url.Action("Delete")?id=${id}`, {
                        method: 'POST'
                    });
                    if (response.ok) {
                        Notification.success('Branch deleted successfully');
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        Notification.error('Failed to delete branch');
                    }
                } catch (error) {
                    Notification.error('An error occurred');
                }
            }
        );
    }
</script>
}
