@model AssistanceManagementSystem.Models.Branch
<h2>إضافة فرع</h2>
<form asp-action="Create" method="post">
    <div>
        <label>الاسم</label>
        <input asp-for="Name" />
    </div>
    <div>
        <label>العنوان</label>
        <input asp-for="Address" />
    </div>
    <div>
        <label>الهاتف</label>
        <input asp-for="Phone" />
    </div>
    <button type="submit">حفظ</button>
    <a asp-action="Index">إلغاء</a>
</form>
