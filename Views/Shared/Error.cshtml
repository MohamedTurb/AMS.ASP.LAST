@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container">
    <div class="empty-state" style="margin-top: 60px; margin-bottom: 60px;">
        <div class="empty-state-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        
        @if (ViewContext.RouteData.Values["action"]?.ToString() == "Index" && ViewContext.HttpContext.Response.StatusCode == 404)
        {
            <h1 class="empty-state-title" style="font-size: var(--font-size-4xl);">404</h1>
            <p class="empty-state-description">Page Not Found</p>
        }
        else if (ViewContext.HttpContext.Response.StatusCode == 500)
        {
            <h1 class="empty-state-title" style="font-size: var(--font-size-4xl);">500</h1>
            <p class="empty-state-description">Internal Server Error</p>
        }
        else
        {
            <h1 class="empty-state-title" style="font-size: var(--font-size-4xl);">Oops!</h1>
            <p class="empty-state-description">Something went wrong</p>
        }

        @if (!string.IsNullOrEmpty(Model?.RequestId))
        {
            <p style="color: var(--color-text-muted); font-size: var(--font-size-sm); margin-bottom: var(--spacing-6);">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }

        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
            <i class="fas fa-home me-2"></i>
            Return to Home
        </a>
    </div>
</div>
