@model AssistanceManagementSystem.Controllers.AnalyticsViewModel
<h2>تحليلات وتقارير</h2>
<div>
    <p>إجمالي الطلبات: @Model.TotalRequests</p>
    <p>الإجمالي (جنيه): @Model.TotalAmount</p>
    <p>المتوسط: @Model.AverageAmount</p>
</div>
<h3>الحالات</h3>
<ul>
@for(int i=0;i<Model.StatusLabels.Count;i++){
    <li>@Model.StatusLabels[i]: @Model.StatusCounts[i]</li>
}
</ul>
<a asp-action="Index">رجوع</a>
