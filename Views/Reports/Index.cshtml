@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="container">
    @{
        ViewBag.Subtitle = "Comprehensive system analytics and reporting";
        ViewBag.Actions = $@"<div class=""btn-group"">
            <button onclick=""exportReport('excel')"" class=""btn btn-outline"">
                <i class=""fas fa-file-excel""></i>
                Export Excel
            </button>
            <button onclick=""exportReport('pdf')"" class=""btn btn-outline"">
                <i class=""fas fa-file-pdf""></i>
                Export PDF
            </button>
        </div>";
    }
    @await Html.PartialAsync("_PageHeader", "Reports & Analytics")

    <!-- Date Range Filter -->
    <div class="card" style="margin-bottom: var(--spacing-6);">
        <div class="card-body">
            <form method="get" asp-action="Index" style="display: flex; gap: var(--spacing-4); flex-wrap: wrap;">
                <div style="flex: 1; min-width: 200px;">
                    <label class="form-label" style="margin-bottom: var(--spacing-1);">From Date</label>
                    <input type="date" name="fromDate" class="form-input" value="@ViewContext.HttpContext.Request.Query["fromDate"]" />
                </div>

                <div style="flex: 1; min-width: 200px;">
                    <label class="form-label" style="margin-bottom: var(--spacing-1);">To Date</label>
                    <input type="date" name="toDate" class="form-input" value="@ViewContext.HttpContext.Request.Query["toDate"]" />
                </div>

                <div style="flex: 1; min-width: 200px;">
                    <label class="form-label" style="margin-bottom: var(--spacing-1);">Branch</label>
                    <select name="branchId" class="form-select">
                        <option value="">All Branches</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary" style="align-self: flex-end;">
                    <i class="fas fa-filter"></i>
                    Apply
                </button>
            </form>
        </div>
    </div>

    <!-- Key Metrics -->
    <div class="dashboard-grid" style="margin-bottom: var(--spacing-8);">
        <div class="stat-card">
            <div class="d-flex items-start gap-4">
                <div class="stat-card-icon primary">
                    <i class="fas fa-file-alt"></i>
                </div>
                <div class="flex-1">
                    <h5 class="stat-card-title">Total Requests</h5>
                    <p class="stat-card-value">@(ViewBag.TotalRequests ?? 0)</p>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="d-flex items-start gap-4">
                <div class="stat-card-icon secondary">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div class="flex-1">
                    <h5 class="stat-card-title">Approved</h5>
                    <p class="stat-card-value">@(ViewBag.ApprovedCount ?? 0)</p>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="d-flex items-start gap-4">
                <div class="stat-card-icon accent">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div class="flex-1">
                    <h5 class="stat-card-title">Total Amount</h5>
                    <p class="stat-card-value">$@(ViewBag.TotalAmount?.ToString("F0") ?? "0")</p>
                </div>
            </div>
        </div>

        <div class="stat-card">
            <div class="d-flex items-start gap-4">
                <div class="stat-card-icon secondary">
                    <i class="fas fa-users"></i>
                </div>
                <div class="flex-1">
                    <h5 class="stat-card-title">Beneficiaries</h5>
                    <p class="stat-card-value">@(ViewBag.BeneficiaryCount ?? 0)</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts -->
    <div class="row" style="margin-bottom: var(--spacing-8);">
        <div class="col-lg-6">
            <div class="chart-container">
                <h5 class="chart-title">Requests by Category</h5>
                <canvas id="categoryChart" style="max-height: 300px;"></canvas>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="chart-container">
                <h5 class="chart-title">Status Distribution</h5>
                <canvas id="statusChart" style="max-height: 300px;"></canvas>
            </div>
        </div>
    </div>

    <!-- Detailed Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 style="margin: 0;">Request Summary by Branch</h5>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Branch</th>
                                <th>Total Requests</th>
                                <th>Approved</th>
                                <th>Pending</th>
                                <th>Rejected</th>
                                <th>Total Amount</th>
                                <th>Disbursed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.BranchSummary?.Count > 0)
                            {
                                @foreach (var branch in ViewBag.BranchSummary)
                                {
                                    <tr>
                                        <td>@branch.Name</td>
                                        <td>@branch.TotalRequests</td>
                                        <td><span class="badge badge-success">@branch.ApprovedCount</span></td>
                                        <td><span class="badge badge-warning">@branch.PendingCount</span></td>
                                        <td><span class="badge badge-danger">@branch.RejectedCount</span></td>
                                        <td>$@branch.TotalAmount.ToString("F2")</td>
                                        <td>$@branch.DisbursedAmount.ToString("F2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-8">No data available</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="~/lib/chart.js/dist/chart.min.js"></script>
<script>
    // Category Chart
    const categoryCtx = document.getElementById('categoryChart')?.getContext('2d');
    if (categoryCtx) {
        new Chart(categoryCtx, {
            type: 'doughnut',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.CategoryLabels ?? new string[0])),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(ViewBag.CategoryCounts ?? new int[0])),
                    backgroundColor: [
                        'rgb(29, 78, 216)',
                        'rgb(5, 150, 105)',
                        'rgb(249, 115, 22)',
                        'rgb(239, 68, 68)',
                        'rgb(59, 130, 246)'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { position: 'bottom' } }
            }
        });
    }

    // Status Chart
    const statusCtx = document.getElementById('statusChart')?.getContext('2d');
    if (statusCtx) {
        new Chart(statusCtx, {
            type: 'bar',
            data: {
                labels: ['Pending', 'Approved', 'Completed', 'Rejected'],
                datasets: [{
                    label: 'Count',
                    data: @Html.Raw(Json.Serialize(ViewBag.StatusCounts ?? new int[0])),
                    backgroundColor: [
                        'rgb(245, 158, 11)',
                        'rgb(16, 185, 129)',
                        'rgb(5, 150, 105)',
                        'rgb(239, 68, 68)'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: { legend: { display: false } }
            }
        });
    }

    function exportReport(format) {
        const from = new URLSearchParams(window.location.search).get('fromDate');
        const to = new URLSearchParams(window.location.search).get('toDate');
        window.location.href = `@Url.Action("Export")/${format}?fromDate=${from}&toDate=${to}`;
    }
</script>
}
