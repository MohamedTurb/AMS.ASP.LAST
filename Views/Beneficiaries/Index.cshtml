@model PaginatedList<Beneficiary>
@{
    ViewData["Title"] = "Beneficiaries";
}

<div class="container">
    <!-- Page Header -->
    @{
        ViewBag.Subtitle = "Manage beneficiary database and profiles";
        ViewBag.Actions = $@"<div class=""btn-group"">
            <a href=""{Url.Action("Create", "Beneficiaries")}"" class=""btn btn-primary"">
                <i class=""fas fa-plus""></i>
                New Beneficiary
            </a>
            <button onclick=""bulkExport()"" class=""btn btn-outline"">
                <i class=""fas fa-download""></i>
                Export
            </button>
        </div>";
    }
    @await Html.PartialAsync("_PageHeader", "Beneficiaries")

    <!-- Search & Filters -->
    <div class="card" style="margin-bottom: var(--spacing-6);">
        <div class="card-body">
            <form method="get" asp-action="Index" class="search-filters">
                <div class="search-box">
                    <input type="text" name="searchString" class="form-input" placeholder="Search by name, ID, phone..." value="@ViewContext.HttpContext.Request.Query["searchString"]" />
                    <i class="fas fa-search search-box-icon"></i>
                </div>

                <div class="filter-group">
                    <select name="aidCategoryId" class="filter-select">
                        <option value="">All Categories</option>
                        @* Categories would be populated *@
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-filter"></i>
                    Filter
                </button>
                <a href="@Url.Action("Index", "Beneficiaries")" class="btn btn-outline">
                    <i class="fas fa-redo"></i>
                    Reset
                </a>
            </form>
        </div>
    </div>

    <!-- Beneficiaries Table -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>National ID</th>
                        <th>Phone</th>
                        <th>Gender</th>
                        <th>Category</th>
                        <th>Assistances</th>
                        <th>Registered</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Count > 0)
                    {
                        @foreach (var beneficiary in Model)
                        {
                            <tr>
                                <td>
                                    <div>
                                        <div style="font-weight: 500;">@beneficiary.FullName</div>
                                        <div style="font-size: var(--font-size-xs); color: var(--color-text-muted);">@beneficiary.Address</div>
                                    </div>
                                </td>
                                <td>@beneficiary.NationalId</td>
                                <td><a href="tel:@beneficiary.Phone">@beneficiary.Phone</a></td>
                                <td>
                                    <span class="badge badge-light">@beneficiary.Gender</span>
                                </td>
                                <td>@beneficiary.AidCategory?.NameEn</td>
                                <td>
                                    <span class="badge badge-primary">@beneficiary.Assistances?.Count</span>
                                </td>
                                <td>@beneficiary.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group" style="gap: var(--spacing-2);">
                                        <a href="@Url.Action("Details", new { id = beneficiary.Id })" class="btn btn-sm btn-outline">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = beneficiary.Id })" class="btn btn-sm btn-outline">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty-state" style="padding: var(--spacing-8) var(--spacing-4);">
                                    <div class="empty-state-icon">
                                        <i class="fas fa-users"></i>
                                    </div>
                                    <p class="empty-state-title">No beneficiaries found</p>
                                    <p class="empty-state-description">
                                        Start by creating a new beneficiary profile.
                                    </p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Model?.TotalPages > 1)
        {
            <div class="card-footer" style="display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size: var(--font-size-sm); color: var(--color-text-muted);">
                    Showing @((Model.PageIndex - 1) * Model.PageSize + 1) to @Math.Min(Model.PageIndex * Model.PageSize, Model.TotalCount) of @Model.TotalCount
                </div>

                <nav aria-label="Page navigation">
                    <ul class="pagination">
                        @if (Model.HasPreviousPage)
                        {
                            <li>
                                <a href="@Url.Action("Index", new { page = Model.PageIndex - 1 })" class="pagination-item">
                                    <i class="fas fa-chevron-left"></i> Previous
                                </a>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            @if (i == Model.PageIndex)
                            {
                                <li>
                                    <span class="pagination-item active">@i</span>
                                </li>
                            }
                            else if (i <= Model.PageIndex + 2 && i >= Model.PageIndex - 2)
                            {
                                <li>
                                    <a href="@Url.Action("Index", new { page = i })" class="pagination-item">@i</a>
                                </li>
                            }
                        }

                        @if (Model.HasNextPage)
                        {
                            <li>
                                <a href="@Url.Action("Index", new { page = Model.PageIndex + 1 })" class="pagination-item">
                                    Next <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>

    <!-- Export Options -->
    <div style="margin-top: var(--spacing-6); display: flex; justify-content: flex-end; gap: var(--spacing-3);">
        <button type="button" class="export-btn" onclick="exportToCSV()">
            <i class="fas fa-file-csv export-btn-icon"></i>
            CSV
        </button>
        <button type="button" class="export-btn" onclick="exportToExcel()">
            <i class="fas fa-file-excel export-btn-icon"></i>
            Excel
        </button>
        <button type="button" class="export-btn" onclick="printList()">
            <i class="fas fa-print export-btn-icon"></i>
            Print
        </button>
    </div>
</div>

@section Scripts {
<script>
    function exportToCSV() {
        Notification.info('Preparing CSV export...');
        window.location.href = '@Url.Action("ExportCsv", "Beneficiaries")?@ViewContext.HttpContext.Request.QueryString';
    }

    function exportToExcel() {
        Notification.info('Preparing Excel export...');
        window.location.href = '@Url.Action("ExportExcel", "Beneficiaries")?@ViewContext.HttpContext.Request.QueryString';
    }

    function printList() {
        window.print();
    }

    function bulkExport() {
        Confirm.show(
            'Export all beneficiaries to Excel?',
            () => exportToExcel()
        );
    }
</script>
}
