# Example environment variables for production deployment
# Copy to .env and fill values (DO NOT commit secrets to git)

ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://0.0.0.0:5001;http://0.0.0.0:5000

# Database
ConnectionStrings__DefaultConnection=Server=your-db-host;Database=your-db;User Id=your-user;Password=your-password;TrustServerCertificate=true;

# File storage provider: Local or S3
FileStorage__Provider=Local
FileStorage__LocalPath=wwwroot/uploads

# Serilog / Logging
Serilog__MinimumLevel=Information

# SMTP (optional)
SMTP__Host=
SMTP__Port=25
SMTP__User=
SMTP__Password=

# Auth providers
Authentication__Google__ClientId=
Authentication__Google__ClientSecret=

# App secrets
APP__SIGNING_KEY=
