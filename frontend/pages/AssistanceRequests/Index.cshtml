@model IEnumerable<AssistanceManagementSystem.Models.AssistanceRequest>
@{
    ViewData["Title"] = "طلبات المساعدة";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderDesc"] = "بحث وتصفية ومتابعة حالات الطلبات.";
    ViewData["PageHeaderEyebrow"] = "العمليات";
    ViewData["PageHeaderIcon"] = "fas fa-file-lines";
    var canCreate = User.IsInRole("Admin") || User.IsInRole("Branch Manager") || User.IsInRole("Staff") || User.IsInRole("Approver") || User.IsInRole("Beneficiary");
    if (canCreate)
    {
        ViewData["PageHeaderActions"] = $"<a href=\"{Url.Action("Create")}\" class=\"ams-btn ams-btn--primary\"><i class=\"fas fa-plus\"></i> طلب جديد</a>";
    }
}

@await Html.PartialAsync("_PageHeader")

<div class="ams-metrics">
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--brand"><i class="fas fa-layer-group"></i></div>
        <div><div class="ams-metric__label">الإجمالي</div><div class="ams-metric__value">@ViewBag.TotalRequests</div></div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--warning"><i class="fas fa-clock"></i></div>
        <div><div class="ams-metric__label">معلق</div><div class="ams-metric__value">@ViewBag.PendingRequests</div></div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--success"><i class="fas fa-check"></i></div>
        <div><div class="ams-metric__label">موافق عليه</div><div class="ams-metric__value">@ViewBag.ApprovedRequests</div></div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--info"><i class="fas fa-flag-checkered"></i></div>
        <div><div class="ams-metric__label">تم التنفيذ</div><div class="ams-metric__value">@ViewBag.ExecutedRequests</div></div>
    </div>
</div>

<div class="ams-card ams-filter">
    <div class="ams-card__body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label" for="searchString">بحث</label>
                <input type="text" id="searchString" name="searchString" class="form-control" value="@ViewBag.SearchString" placeholder="الاسم، الرقم القومي، الهاتف..." />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="typeFilter">نوع المساعدة</label>
                <select id="typeFilter" name="typeFilter" class="form-select">
                    <option value="">الكل</option>
                    @foreach (var type in ViewBag.Types)
                    {
                        <option value="@type" selected="@(ViewBag.TypeFilter == type)">@type</option>
                    }
                </select>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <div class="col-md-2">
                    <label class="form-label" for="branchFilter">الفرع</label>
                    <select id="branchFilter" name="branchFilter" class="form-select">
                        <option value="">الكل</option>
                        @if (ViewBag.Branches != null)
                        {
                            foreach (var b in (IEnumerable<dynamic>)ViewBag.Branches)
                            {
                                <option value="@b.Id" selected="@(ViewBag.BranchFilter != null && (int)ViewBag.BranchFilter == b.Id)">@b.Name</option>
                            }
                        }
                    </select>
                </div>
            }
            <div class="col-md-2">
                <label class="form-label" for="statusFilter">الحالة</label>
                <select id="statusFilter" name="statusFilter" class="form-select">
                    <option value="">الكل</option>
                    @foreach (var status in ViewBag.Statuses)
                    {
                        <option value="@status" selected="@(ViewBag.StatusFilter == status)">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label" for="dateFrom">من</label>
                <input type="date" id="dateFrom" name="dateFrom" class="form-control" value="@ViewBag.DateFrom" />
            </div>
            <div class="col-md-2">
                <label class="form-label" for="dateTo">إلى</label>
                <input type="date" id="dateTo" name="dateTo" class="form-control" value="@ViewBag.DateTo" />
            </div>
            <div class="col-md-1 d-grid">
                <button type="submit" class="ams-btn ams-btn--primary"><i class="fas fa-search"></i></button>
            </div>
        </form>
    </div>
</div>

<div class="ams-card">
    <div class="ams-card__body p-0">
        @if (Model.Any())
        {
            <div class="ams-table-wrap">
                <table class="ams-table mb-0">
                    <thead>
                        <tr>
                            <th>رقم</th>
                            <th>طالب المساعدة</th>
                            <th>المستفيد</th>
                            <th>الفرع</th>
                            <th>النوع</th>
                            <th>المبلغ</th>
                            <th>الحالة</th>
                            <th>التاريخ</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <span class="ams-fw-semibold">#@item.Id</span>
                                    <div class="small ams-text-muted">@(item.ReferenceNumber ?? "—")</div>
                                </td>
                                <td>
                                    <div class="ams-fw-semibold">@(!string.IsNullOrWhiteSpace(item.RequesterNameAr) ? item.RequesterNameAr : item.RequesterName)</div>
                                    <small class="ams-text-muted">@item.RequesterPhoneNumber</small>
                                </td>
                                <td>
                                    <div class="ams-fw-semibold">@(!string.IsNullOrWhiteSpace(item.BeneficiaryNameAr) ? item.BeneficiaryNameAr : item.BeneficiaryName)</div>
                                    <small class="ams-text-muted">@item.BeneficiaryPhoneNumber</small>
                                </td>
                                <td>@item.Branch?.Name</td>
                                <td>@item.TypeOfAssistance</td>
                                <td>@(item.Amount.HasValue ? $"{item.Amount:N0} جنيه" : "—")</td>
                                <td>@await Html.PartialAsync("_StatusBadge", item.Status)</td>
                                <td>@item.CreatedAt.ToString("yyyy/MM/dd")</td>
                                <td>
                                    <div class="ams-flex ams-gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm"><i class="fas fa-eye"></i></a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Branch Manager") || User.IsInRole("Staff"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm"><i class="fas fa-pen"></i></a>
                                        }
                                        @if (User.IsInRole("Admin") || User.IsInRole("Branch Manager"))
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm ams-text-danger"><i class="fas fa-trash"></i></a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            ViewData["EmptyTitle"] = "لا توجد طلبات";
            ViewData["EmptyText"] = "لم يتم العثور على طلبات تطابق معايير البحث.";
            if (canCreate)
            {
                ViewData["EmptyAction"] = $"<a href=\"{Url.Action("Create")}\" class=\"ams-btn ams-btn--primary\"><i class=\"fas fa-plus\"></i> طلب جديد</a>";
            }
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
