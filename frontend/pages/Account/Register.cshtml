@model AssistanceManagementSystem.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "إنشاء حساب";
    Layout = "_AuthLayout";
}

<div class="ams-auth-card__logo"><i class="fas fa-user-plus"></i></div>
<h1>إنشاء حساب</h1>
<p class="text-muted">سجّل كمستفيد للوصول إلى خدمات المساعدات</p>

<form asp-action="Register" method="post">
    <div asp-validation-summary="All" class="alert alert-danger py-2"></div>

    <div class="mb-3">
        <label asp-for="FullName" class="form-label">الاسم الكامل</label>
        <input asp-for="FullName" class="form-control form-control-lg" />
        <span asp-validation-for="FullName" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
        <input asp-for="Email" class="form-control form-control-lg" placeholder="name@example.com" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">كلمة المرور</label>
        <input asp-for="Password" class="form-control form-control-lg" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <label asp-for="BranchId" class="form-label">الفرع (اختياري)</label>
        <select asp-for="BranchId" class="form-select form-select-lg">
            <option value="">— اختر الفرع —</option>
            @foreach (var b in (IEnumerable<AssistanceManagementSystem.Models.Branch>)ViewBag.Branches)
            {
                <option value="@b.Id">@b.Name</option>
            }
        </select>
    </div>

    <button type="submit" class="ams-btn ams-btn--primary ams-w-full ams-btn--lg">
        <i class="fas fa-user-plus"></i> إنشاء الحساب
    </button>
</form>

<p class="text-center mt-4 mb-0">
    لديك حساب؟ <a asp-action="Login" class="ams-text-brand">تسجيل الدخول</a>
</p>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
