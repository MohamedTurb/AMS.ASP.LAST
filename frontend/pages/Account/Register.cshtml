@model AssistanceManagementSystem.Controllers.RegisterViewModel

@{
    ViewData["Title"] = "إنشاء حساب";
    Layout = "_Layout";
}

<div class="login-shell">
    <div class="row g-0 align-items-stretch justify-content-center">
        <div class="col-lg-6">
            <div class="login-panel p-4 p-md-5 h-100">
                <div class="card glass-surface shadow-sm border-0">
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4">
                            <div class="login-badge mb-3"><i class="fas fa-user-plus"></i></div>
                            <h3 class="mb-2">إنشاء حساب جديد</h3>
                            <p class="text-muted mb-0">سجّل حسابًا جديدًا للوصول إلى الخدمات</p>
                        </div>

                        <form asp-action="Register" method="post">
                            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                                <input asp-for="FullName" class="form-control form-control-lg" />
                                <div class="invalid-feedback d-block" asp-validation-for="FullName"></div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                                <input asp-for="Email" class="form-control form-control-lg" placeholder="name@example.com" />
                                <div class="invalid-feedback d-block" asp-validation-for="Email"></div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label">كلمة المرور</label>
                                <input asp-for="Password" class="form-control form-control-lg" />
                                <div class="invalid-feedback d-block" asp-validation-for="Password"></div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="BranchId" class="form-label">الفرع (اختياري)</label>
                                <select asp-for="BranchId" class="form-select">
                                    <option value="">-- اختر الفرع --</option>
                                    @foreach (var b in (IEnumerable<AssistanceManagementSystem.Models.Branch>)ViewBag.Branches)
                                    {
                                        <option value="@b.Id">@b.Name</option>
                                    }
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100 mb-3">
                                <i class="fas fa-user-plus me-2"></i>إنشاء الحساب
                            </button>

                            <div class="text-center">
                                لديك حساب؟ <a href="@Url.Action("Login", "Account")">سجل الدخول</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
