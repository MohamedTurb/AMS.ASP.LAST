@model IEnumerable<AssistanceManagementSystem.Controllers.UserViewModel>
@{
    ViewData["Title"] = "المستخدمون";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderIcon"] = "fas fa-user-gear";
    ViewData["PageHeaderActionText"] = User.IsInRole("Admin") ? "مستخدم جديد" : null;
    ViewData["PageHeaderActionUrl"] = User.IsInRole("Admin") ? Url.Action("Create") : null;
}

@await Html.PartialAsync("_PageHeader")

<div class="ams-card">
    <div class="ams-card__body p-0">
        @if (Model.Any())
        {
            <div class="ams-table-wrap">
                <table class="ams-table mb-0">
                    <thead>
                        <tr>
                            <th>المستخدم</th>
                            <th>البريد</th>
                            <th>الاسم</th>
                            <th>الفرع</th>
                            <th>الأدوار</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ams-fw-semibold">@item.UserName</td>
                                <td>@item.Email</td>
                                <td>@item.FullName</td>
                                <td>@item.BranchName</td>
                                <td><span class="ams-badge ams-badge--neutral">@item.Roles</span></td>
                                <td>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="ams-flex ams-gap-2">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm"><i class="fas fa-pen"></i></a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm ams-text-danger"><i class="fas fa-trash"></i></a>
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
