@model IEnumerable<AssistanceManagementSystem.Controllers.UserViewModel>

@{
    ViewData["Title"] = "إدارة المستخدمين";
}

@{
    ViewData["PageHeaderTitle"] = ViewData["Title"]?.ToString() ?? "";
    ViewData["PageHeaderIcon"] = "fas fa-user-cog";
    ViewData["PageHeaderActionText"] = User.IsInRole("Admin") ? "إضافة مستخدم جديد" : null;
    ViewData["PageHeaderActionUrl"] = User.IsInRole("Admin") ? Url.Action("Create", "Account") : null;
}
@{ await Html.RenderPartialAsync("_PageHeader"); }

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>اسم المستخدم</th>
                            <th>البريد الإلكتروني</th>
                            <th>الاسم الكامل</th>
                            <th>الفرع</th>
                            <th>الأدوار</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.UserName</td>
                                <td>@item.Email</td>
                                <td>@item.FullName</td>
                                <td>@item.BranchName</td>
                                <td>
                                    <span class="badge bg-primary">@item.Roles</span>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">لا توجد مستخدمين</h5>
                <p class="text-muted">ابدأ بإضافة مستخدم جديد</p>
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-user-plus me-2"></i>إضافة مستخدم جديد
                    </a>
                }
            </div>
        }
    </div>
</div>
