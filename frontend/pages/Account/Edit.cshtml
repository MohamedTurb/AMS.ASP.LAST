@model AssistanceManagementSystem.Controllers.EditUserViewModel

@{
    ViewData["Title"] = "تعديل المستخدم";
}

@{
    ViewData["PageHeaderTitle"] = ViewData["Title"]?.ToString() ?? "";
    ViewData["PageHeaderIcon"] = "fas fa-user-edit";
}
@{ @await Html.PartialAsync("_PageHeader") }

<div class="row g-3">
    <div class="col-lg-8">
        <div class="ams-card">
            <div class="card-body">
                <form asp-action="Edit" class="row g-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="col-md-6">
                        <label asp-for="UserName" class="form-label">اسم المستخدم</label>
                        <input asp-for="UserName" class="form-control" readonly />
                        <span asp-validation-for="UserName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
                        <input asp-for="Email" type="email" class="form-control" readonly />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="BranchId" class="form-label">الفرع</label>
                        <select asp-for="BranchId" class="form-select" asp-items="@(new SelectList(ViewBag.Branches, "Id", "Name"))">
                            <option value="">اختر الفرع</option>
                        </select>
                        <span asp-validation-for="BranchId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Role" class="form-label">الدور</label>
                        <select asp-for="Role" class="form-select">
                            <option value="">اختر الدور</option>
                            @foreach (var role in ViewBag.Roles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                        <span asp-validation-for="Role" class="text-danger"></span>
                    </div>

                    <div class="col-12 d-flex flex-wrap gap-2 mt-2">
                        <button type="submit" class="ams-btn ams-btn--primary">
                            <i class="fas fa-save me-2"></i>حفظ التغييرات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-right me-2"></i>العودة للقائمة
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

