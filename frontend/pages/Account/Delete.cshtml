@model AssistanceManagementSystem.Controllers.UserViewModel

@{
    ViewData["Title"] = "حذف المستخدم";
}

@{
    ViewData["PageHeaderTitle"] = ViewData["Title"]?.ToString() ?? "";
    ViewData["PageHeaderIcon"] = "fas fa-user-times text-danger";
}
@{ await Html.RenderPartialAsync("_PageHeader"); }

<div class="page-shell">
    <div class="page-hero p-4 p-lg-5 mb-4">
        <div class="hero-copy row align-items-center g-4">
            <div class="col-lg-8">
                <div class="hero-chip"><i class="fas fa-user-times"></i>حذف مستخدم</div>
                <h1 class="hero-title">@ViewData["Title"]</h1>
                <p class="hero-subtitle mb-0">سيتم حذف الحساب نهائيًا مع الحفاظ على اتساق بيانات النظام المرتبطة به.</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a asp-action="Index" class="btn btn-light btn-lg"><i class="fas fa-arrow-right me-2"></i>العودة</a>
            </div>
        </div>
    </div>

<div class="row">
    <div class="col-md-8">
        <div class="card danger-shell">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="fas fa-exclamation-triangle me-2"></i>تحذير
                </h5>
            </div>
            <div class="card-body">
                <p class="text-danger mb-3">
                    <strong>هل أنت متأكد من حذف هذا المستخدم؟</strong>
                </p>
                <p class="text-muted">سيتم حذف جميع البيانات المرتبطة بهذا المستخدم نهائياً.</p>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>اسم المستخدم:</strong>
                        <p class="text-muted">@Model.UserName</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>البريد الإلكتروني:</strong>
                        <p class="text-muted">@Model.Email</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>الاسم الكامل:</strong>
                        <p class="text-muted">@Model.FullName</p>
                    </div>
                    <div class="col-md-6 mb-3">
                        <strong>الفرع:</strong>
                        <p class="text-muted">@Model.BranchName</p>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <strong>الأدوار:</strong>
                        <p class="text-muted">@Model.Roles</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</div>
