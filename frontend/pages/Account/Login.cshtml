@model AssistanceManagementSystem.Controllers.LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
    Layout = "_AuthLayout";
    var returnUrl = string.IsNullOrWhiteSpace((string?)ViewData["ReturnUrl"]) ? Url.Action("Index", "Home") : (string?)ViewData["ReturnUrl"];
}

<div class="ams-auth-card__logo"><i class="fas fa-hands-helping"></i></div>
<h1>مرحباً بعودتك</h1>
<p class="text-muted">سجّل الدخول للوصول إلى لوحة التحكم</p>

<div class="d-grid gap-2 mb-4">
    <a class="ams-btn ams-btn-google ams-w-full ams-btn--lg" href="/api/v1/auth/external/google?redirectUri=@Uri.EscapeDataString(returnUrl ?? "/")">
        <i class="fab fa-google"></i> المتابعة عبر Google
    </a>
    <a class="ams-btn ams-btn-microsoft ams-w-full ams-btn--lg" href="/api/v1/auth/external/microsoft?redirectUri=@Uri.EscapeDataString(returnUrl ?? "/")">
        <i class="fab fa-microsoft"></i> المتابعة عبر Microsoft
    </a>
</div>

<div class="ams-divider"><span>أو بالبريد الإلكتروني</span></div>

<form asp-action="Login" method="post">
    <input type="hidden" name="returnUrl" value="@returnUrl" />
    <div asp-validation-summary="All" class="alert alert-danger py-2"></div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label">البريد الإلكتروني</label>
        <input asp-for="Email" class="form-control form-control-lg" placeholder="name@example.com" autocomplete="username" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label">كلمة المرور</label>
        <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" />
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="mb-4 form-check">
        <input asp-for="RememberMe" class="form-check-input" />
        <label asp-for="RememberMe" class="form-check-label">تذكرني</label>
    </div>

    <button type="submit" class="ams-btn ams-btn--primary ams-w-full ams-btn--lg">
        <i class="fas fa-right-to-bracket"></i> تسجيل الدخول
    </button>
</form>

<p class="text-center mt-4 mb-0">
    لا تملك حساباً؟ <a asp-action="Register" class="ams-text-brand">إنشاء حساب</a>
</p>

<div class="ams-demo-box">
    <strong class="d-block mb-2">حسابات تجريبية</strong>
    <div class="row g-2 small ams-text-muted">
        <div class="col-6">admin@ams.com / Admin123!</div>
        <div class="col-6">manager@ams.com / Manager123!</div>
        <div class="col-6">staff@ams.com / Staff123!</div>
        <div class="col-6">beneficiary@ams.com / Beneficiary123!</div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
