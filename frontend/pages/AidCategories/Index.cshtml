@model IEnumerable<AssistanceManagementSystem.Models.AidCategory>
@{
    ViewData["Title"] = "التصنيفات";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderIcon"] = "fas fa-tags";
    ViewData["PageHeaderDesc"] = "تصنيفات المساعدات والهيكل الهرمي.";
    ViewData["PageHeaderActionText"] = "إضافة تصنيف";
    ViewData["PageHeaderActionUrl"] = Url.Action("Create");
}

@await Html.PartialAsync("_PageHeader")

<div class="ams-card">
    <div class="ams-card__body p-0">
        @if (Model.Any())
        {
            <div class="ams-table-wrap">
                <table class="ams-table mb-0">
                    <thead>
                        <tr>
                            <th>الاسم</th>
                            <th>الرمز</th>
                            <th>النطاق</th>
                            <th>الأب</th>
                            <th>الترتيب</th>
                            <th>الحالة</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="ams-fw-semibold">@item.NameAr</div>
                                    @if (!string.IsNullOrWhiteSpace(item.NameEn))
                                    {
                                        <small class="ams-text-muted">@item.NameEn</small>
                                    }
                                </td>
                                <td>@(item.Code ?? "—")</td>
                                <td>@item.Scope</td>
                                <td>@(item.ParentAidCategory?.NameAr ?? "—")</td>
                                <td>@item.SortOrder</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="ams-badge ams-badge--approved">نشط</span>
                                    }
                                    else
                                    {
                                        <span class="ams-badge ams-badge--neutral">غير نشط</span>
                                    }
                                </td>
                                <td>
                                    <div class="ams-flex ams-gap-2">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm"><i class="fas fa-pen"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="ams-btn ams-btn--ghost ams-btn--sm ams-text-danger"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            ViewData["EmptyTitle"] = "لا توجد تصنيفات";
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
