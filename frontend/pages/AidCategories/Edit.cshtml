@model AssistanceManagementSystem.Models.AidCategory

@{
    ViewData["Title"] = "تعديل التصنيف";
}

@{
    ViewData["PageHeaderTitle"] = ViewData["Title"]?.ToString() ?? "";
    ViewData["PageHeaderIcon"] = "fas fa-tags";
}
@{ await Html.RenderPartialAsync("_PageHeader"); }

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card glass-surface">
            <div class="card-body">
                <form asp-action="Edit" class="row g-3">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-md-6">
                        <label asp-for="NameAr" class="form-label">الاسم بالعربية</label>
                        <input asp-for="NameAr" class="form-control" />
                        <span asp-validation-for="NameAr" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NameEn" class="form-label">الاسم بالإنجليزية</label>
                        <input asp-for="NameEn" class="form-control" />
                        <span asp-validation-for="NameEn" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Code" class="form-label">الرمز</label>
                        <input asp-for="Code" class="form-control" />
                        <span asp-validation-for="Code" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Scope" class="form-label">النطاق</label>
                        <input asp-for="Scope" class="form-control" placeholder="Both / Request / Other" />
                        <span asp-validation-for="Scope" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SortOrder" class="form-label">الترتيب</label>
                        <input asp-for="SortOrder" class="form-control" type="number" />
                        <span asp-validation-for="SortOrder" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label">الوصف</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ParentAidCategoryId" class="form-label">التصنيف الأب</label>
                        <select asp-for="ParentAidCategoryId" class="form-select" asp-items="ViewBag.ParentCategories">
                            <option value="">بدون</option>
                        </select>
                        <span asp-validation-for="ParentAidCategoryId" class="text-danger"></span>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">نشط</label>
                        </div>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input asp-for="AllowCustomText" class="form-check-input" />
                            <label asp-for="AllowCustomText" class="form-check-label">يسمح بالنص الحر</label>
                        </div>
                    </div>

                    <div class="col-12 d-flex flex-wrap gap-2 mt-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>حفظ التغييرات
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-right me-2"></i>العودة للقائمة
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}