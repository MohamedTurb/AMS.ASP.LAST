@model IEnumerable<AssistanceManagementSystem.Models.Assistance>
@{
    ViewData["Title"] = "صرف المساعدات";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderIcon"] = "fas fa-wallet";
    ViewData["PageHeaderDesc"] = "قائمة المساعدات الجاهزة للصرف.";
}

@await Html.PartialAsync("_PageHeader")

<div class="ams-card ams-filter">
    <div class="ams-card__body">
        <form method="get" class="ams-flex ams-flex-wrap ams-gap-2">
            <input type="text" name="search" class="form-control" style="max-width:320px" placeholder="بحث برقم المرجع..." />
            <button type="submit" class="ams-btn ams-btn--primary"><i class="fas fa-search"></i> بحث</button>
        </form>
    </div>
</div>

<div class="ams-card">
    <div class="ams-card__body p-0">
        @if (Model.Any())
        {
            <div class="ams-table-wrap">
                <table class="ams-table mb-0">
                    <thead>
                        <tr>
                            <th>المرجع</th>
                            <th>المستفيد</th>
                            <th>النوع</th>
                            <th>المبلغ</th>
                            <th>التاريخ</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in Model)
                        {
                            <tr>
                                <td>@(a.ReferenceNumber ?? a.AssistanceRequest?.ReferenceNumber ?? "—")</td>
                                <td>
                                    <div class="ams-fw-semibold">@(a.Beneficiary?.FullNameAr ?? a.Beneficiary?.FullName ?? "—")</div>
                                    <small class="ams-text-muted">#@a.BeneficiaryId</small>
                                </td>
                                <td>@a.Type</td>
                                <td class="ams-text-success ams-fw-bold">@a.Amount.ToString("N0") جنيه</td>
                                <td>@a.CreatedAt.ToString("yyyy/MM/dd HH:mm")</td>
                                <td>
                                    <a asp-controller="AssistanceRequests" asp-action="Details" asp-route-id="@a.AssistanceRequestId" class="ams-btn ams-btn--primary ams-btn--sm">
                                        تفاصيل الطلب
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            ViewData["EmptyTitle"] = "لا توجد مساعدات للصرف";
            ViewData["EmptyText"] = "لا توجد عناصر جاهزة حالياً.";
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
