@model IEnumerable<AssistanceManagementSystem.Models.Notification>

@{
    ViewData["Title"] = "الإشعارات";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <h2>@ViewData["Title"]</h2>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <ul class="list-group">
                @foreach (var n in Model)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <div>@n.Message</div>
                            @if (!string.IsNullOrEmpty(n.Link)) { <a href="@n.Link">عرض</a> }
                            <div class="text-muted small">@n.CreatedAt.ToString("yyyy/MM/dd HH:mm")</div>
                        </div>
                        <div>
                            @if (!n.IsRead)
                            {
                                <form method="post" asp-action="MarkRead" class="d-inline">
                                    <input type="hidden" name="id" value="@n.Id" />
                                    <button class="btn btn-sm btn-primary">تعليم كمقروء</button>
                                </form>
                            }
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <div class="text-center py-5 text-muted">لا توجد إشعارات</div>
        }
    </div>
</div>