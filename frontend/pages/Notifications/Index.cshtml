@model IEnumerable<AssistanceManagementSystem.Models.Notification>
@{
    ViewData["Title"] = "الإشعارات";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderIcon"] = "fas fa-bell";
    ViewData["PageHeaderDesc"] = "جميع الإشعارات والتنبيهات الخاصة بحسابك.";
}

@await Html.PartialAsync("_PageHeader")

<div class="ams-card">
    <div class="ams-card__body">
        @if (Model.Any())
        {
            <div class="list-group list-group-flush">
                @foreach (var n in Model)
                {
                    <div class="list-group-item px-0 d-flex justify-content-between align-items-start gap-3 border-0 border-bottom">
                        <div>
                            <div class="ams-fw-semibold">@n.Message</div>
                            @if (!string.IsNullOrEmpty(n.Link))
                            {
                                <a href="@n.Link" class="small ams-text-brand">عرض التفاصيل</a>
                            }
                            <div class="small ams-text-muted mt-1">@n.CreatedAt.ToString("yyyy/MM/dd HH:mm")</div>
                        </div>
                        @if (!n.IsRead)
                        {
                            <form method="post" asp-action="MarkRead">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="ams-btn ams-btn--primary ams-btn--sm">تعليم كمقروء</button>
                            </form>
                        }
                        else
                        {
                            <span class="ams-badge ams-badge--neutral">مقروء</span>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            ViewData["EmptyIcon"] = "fa-bell-slash";
            ViewData["EmptyTitle"] = "لا توجد إشعارات";
            ViewData["EmptyText"] = "ستظهر التنبيهات هنا عند وصولها.";
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
