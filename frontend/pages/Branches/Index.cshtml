@model IEnumerable<AssistanceManagementSystem.Models.Branch>
@{
    ViewData["Title"] = "الفروع";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderIcon"] = "fas fa-code-branch";
    ViewData["PageHeaderDesc"] = "إدارة الفروع ولوحات المتابعة.";
    ViewData["PageHeaderActionText"] = "إضافة فرع";
    ViewData["PageHeaderActionUrl"] = Url.Action("Create");
}

@await Html.PartialAsync("_PageHeader")

<div class="ams-card">
    <div class="ams-card__body p-0">
        @if (Model.Any())
        {
            <div class="ams-table-wrap">
                <table class="ams-table mb-0">
                    <thead>
                        <tr>
                            <th>الفرع</th>
                            <th>العنوان</th>
                            <th>الهاتف</th>
                            <th>لوحة</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var branch in Model)
                        {
                            <tr>
                                <td class="ams-fw-semibold">@branch.Name</td>
                                <td>@(branch.Address ?? "—")</td>
                                <td>@(branch.Phone ?? "—")</td>
                                <td>
                                    <a asp-action="Dashboard" asp-route-id="@branch.Id" class="ams-btn ams-btn--ghost ams-btn--sm">
                                        <i class="fas fa-chart-line"></i> Dashboard
                                    </a>
                                </td>
                                <td>
                                    <div class="ams-flex ams-gap-2">
                                        <a asp-action="Details" asp-route-id="@branch.Id" class="ams-btn ams-btn--ghost ams-btn--sm"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@branch.Id" class="ams-btn ams-btn--ghost ams-btn--sm"><i class="fas fa-pen"></i></a>
                                        <a asp-action="Delete" asp-route-id="@branch.Id" class="ams-btn ams-btn--ghost ams-btn--sm ams-text-danger"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
