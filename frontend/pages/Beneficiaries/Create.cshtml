@model AssistanceManagementSystem.Models.Beneficiary

@{
    ViewData["Title"] = "إضافة مستفيد جديد";
}

<div class="ams-mb-6">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div>
            <div class="eyebrow mb-2">نموذج</div>
            <h1 class="h3 fw-bold text-white mb-1"><i class="fas fa-user-plus me-2"></i>@ViewData["Title"]</h1>
            <p class="text-white-50 mb-0">أدخل البيانات الأساسية للمستفيد بنفس لغة وبنية باقي النماذج.</p>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="ams-card">
            <div class="card-body">
                <form asp-action="Create" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">الاسم الكامل</label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NationalId" class="form-label">الرقم القومي</label>
                        <input asp-for="NationalId" class="form-control" maxlength="14" />
                        <span asp-validation-for="NationalId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Phone" class="form-label">رقم التليفون</label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label">الجنس</label>
                        <input asp-for="Gender" class="form-control" />
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Religion" class="form-label">الديانة</label>
                        <input asp-for="Religion" class="form-control" />
                        <span asp-validation-for="Religion" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MaritalStatus" class="form-label">الحالة الاجتماعية</label>
                        <input asp-for="MaritalStatus" class="form-control" />
                        <span asp-validation-for="MaritalStatus" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FamilyMembers" class="form-label">أفراد الأسرة</label>
                        <input asp-for="FamilyMembers" class="form-control" />
                        <span asp-validation-for="FamilyMembers" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Income" class="form-label">الدخل الشهري</label>
                        <input asp-for="Income" class="form-control" />
                        <span asp-validation-for="Income" class="text-danger"></span>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="col-md-6">
                            <label class="form-label">الفرع</label>
                            <select asp-for="BranchId" class="form-select">
                                <option value="">اختر الفرع</option>
                                @foreach (var b in ViewBag.Branches)
                                {
                                    <option value="@b.Id">@b.Name</option>
                                }
                            </select>
                        </div>
                    }

                    <div class="col-12 d-flex flex-wrap gap-2 mt-2">
                        <button class="ams-btn ams-btn--primary"><i class="fas fa-save me-2"></i>حفظ</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">العودة</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

