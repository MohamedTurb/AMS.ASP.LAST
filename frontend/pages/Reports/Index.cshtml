@{
    ViewData["Title"] = "التقارير";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderIcon"] = "fas fa-chart-bar";
    ViewData["PageHeaderDesc"] = "تصدير Excel أو PDF مع فلاتر متقدمة.";
    ViewData["PageHeaderActions"] = $"<a href=\"{Url.Action("Analytics")}\" class=\"ams-btn ams-btn--secondary\"><i class=\"fas fa-chart-pie\"></i> التحليلات</a>";
}

@await Html.PartialAsync("_PageHeader")

<div class="row g-4">
    <div class="col-lg-8">
        <div class="ams-card h-100">
            <div class="ams-card__header">
                <h2 class="ams-card__title">إعدادات التقرير</h2>
                <p class="ams-card__subtitle">اختر النوع والفلاتر ثم ولّد الملف</p>
            </div>
            <div class="ams-card__body">
                <form asp-action="GenerateReport" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <div class="col-md-6">
                        <label class="form-label">نوع التقرير</label>
                        <select name="reportType" class="form-select" required>
                            <option value="">اختر النوع</option>
                            <option value="excel">Excel</option>
                            <option value="pdf">PDF</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">نوع المساعدة</label>
                        <select name="typeFilter" class="form-select">
                            <option value="">الكل</option>
                            @foreach (var type in ViewBag.Types)
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">الحالة</label>
                        <select name="statusFilter" class="form-select">
                            <option value="">الكل</option>
                            @foreach (var status in ViewBag.Statuses)
                            {
                                <option value="@status">@status</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">الفرع</label>
                        <select name="branchFilter" class="form-select">
                            <option value="">الكل</option>
                            @foreach (var branch in ViewBag.Branches)
                            {
                                <option value="@branch.Id">@branch.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">من تاريخ</label>
                        <input type="date" name="dateFrom" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">إلى تاريخ</label>
                        <input type="date" name="dateTo" class="form-control" />
                    </div>
                    <div class="col-12">
                        <button type="submit" class="ams-btn ams-btn--primary ams-btn--lg">
                            <i class="fas fa-download"></i> توليد التقرير
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="ams-card h-100">
            <div class="ams-card__body d-flex flex-column justify-content-between">
                <div>
                    <span class="ams-badge ams-badge--neutral mb-3">تحليلات</span>
                    <h3 class="h5 ams-fw-bold">لوحة الرسوم البيانية</h3>
                    <p class="ams-text-muted">توزيع الحالات والأنواع والفروع عبر Chart.js.</p>
                </div>
                <a asp-action="Analytics" class="ams-btn ams-btn--primary ams-w-full mt-4">
                    <i class="fas fa-chart-pie"></i> فتح التحليلات
                </a>
            </div>
        </div>
    </div>
</div>
