@model AssistanceManagementSystem.Controllers.AnalyticsViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "التحليلات";
    ViewData["PageHeaderTitle"] = ViewData["Title"];
    ViewData["PageHeaderIcon"] = "fas fa-chart-pie";
    ViewData["PageHeaderDesc"] = "رسوم بيانية وقراءات سريعة لحركة المساعدات.";
    ViewData["PageHeaderActions"] = $"<a href=\"{Url.Action("Index")}\" class=\"ams-btn ams-btn--secondary\"><i class=\"fas fa-file-export\"></i> التقارير</a>";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/analytics.css" asp-append-version="true" />
}

@await Html.PartialAsync("_PageHeader")

<div class="analytics-page">

    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="card dashboard-card metric-card h-100">
                <div class="card-body">
                    <div class="metric-icon text-warning"><i class="fas fa-hourglass-half"></i></div>
                    <div>
                        <div class="metric-label">معلقة</div>
                        <div class="metric-value">@Model.PendingRequests</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card dashboard-card metric-card h-100">
                <div class="card-body">
                    <div class="metric-icon text-success"><i class="fas fa-check-circle"></i></div>
                    <div>
                        <div class="metric-label">موافق عليها</div>
                        <div class="metric-value">@Model.ApprovedRequests</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card dashboard-card metric-card h-100">
                <div class="card-body">
                    <div class="metric-icon text-danger"><i class="fas fa-ban"></i></div>
                    <div>
                        <div class="metric-label">مرفوضة</div>
                        <div class="metric-value">@Model.RejectedRequests</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="card dashboard-card metric-card h-100">
                <div class="card-body">
                    <div class="metric-icon text-info"><i class="fas fa-wallet"></i></div>
                    <div>
                        <div class="metric-label">تم التنفيذ</div>
                        <div class="metric-value">@Model.ExecutedRequests</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="ams-card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">الفرع</label>
                    <select name="branchFilter" class="form-select">
                        <option value="">جميع الفروع</option>
                        @foreach (var branch in (IEnumerable<AssistanceManagementSystem.Models.Branch>)ViewBag.Branches)
                        {
                            <option value="@branch.Id" selected="@(ViewBag.BranchFilter != null && (int)ViewBag.BranchFilter == branch.Id)">@branch.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">من تاريخ</label>
                    <input type="date" name="dateFrom" class="form-control" value="@ViewBag.DateFrom" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">إلى تاريخ</label>
                    <input type="date" name="dateTo" class="form-control" value="@ViewBag.DateTo" />
                </div>
                <div class="col-md-2 d-grid">
                    <button type="submit" class="ams-btn ams-btn--primary">
                        <i class="fas fa-filter me-2"></i>تحديث
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card h-100  chart-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <div>
                        <div class="section-kicker mb-1">اتجاه زمني</div>
                        <h5 class="card-title mb-0"><i class="fas fa-chart-line me-2"></i>الطلبات خلال آخر 6 أشهر</h5>
                    </div>
                    <span class="badge bg-light text-dark">منحنى زمني</span>
                </div>
                <div class="card-body">
                    <div class="chart-wrap">
                        <canvas id="monthlyChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100  insight-card">
                <div class="card-header">
                    <div class="section-kicker mb-1">موجز</div>
                    <h5 class="card-title mb-0"><i class="fas fa-bullseye me-2"></i>أهم المؤشرات</h5>
                </div>
                <div class="card-body d-grid gap-3">
                    <div class="p-3 rounded-3 bg-light">
                        <div class="text-muted small">أكثر نوع طلب نشاطًا</div>
                        <div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.TopType) ? "غير متوفر" : Model.TopType)</div>
                    </div>
                    <div class="p-3 rounded-3 bg-light">
                        <div class="text-muted small">أكثر فرع نشاطًا</div>
                        <div class="fw-bold">@(string.IsNullOrWhiteSpace(Model.TopBranch) ? "غير متوفر" : Model.TopBranch)</div>
                    </div>
                    <div class="p-3 rounded-3 bg-light">
                        <div class="text-muted small">إجمالي المبالغ</div>
                        <div class="fw-bold text-success">@Model.TotalAmount.ToString("N0") جنيه</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card h-100  chart-card">
                <div class="card-header">
                    <div class="section-kicker mb-1">حالات</div>
                    <h5 class="card-title mb-0"><i class="fas fa-chart-donut me-2"></i>توزيع الحالات</h5>
                </div>
                <div class="card-body">
                    <div class="chart-wrap">
                        <canvas id="statusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100  chart-card">
                <div class="card-header">
                    <div class="section-kicker mb-1">أنواع</div>
                    <h5 class="card-title mb-0"><i class="fas fa-layer-group me-2"></i>أكثر أنواع المساعدة</h5>
                </div>
                <div class="card-body">
                    <div class="chart-wrap">
                        <canvas id="typeChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card h-100  chart-card">
                <div class="card-header">
                    <div class="section-kicker mb-1">فروع</div>
                    <h5 class="card-title mb-0"><i class="fas fa-code-branch me-2"></i>الفروع الأكثر طلبًا</h5>
                </div>
                <div class="card-body">
                    <div class="chart-wrap">
                        <canvas id="branchChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const monthlyLabels = @Html.Raw(JsonSerializer.Serialize(Model.MonthLabels));
        const monthlyCounts = @Html.Raw(JsonSerializer.Serialize(Model.MonthCounts));
        const statusLabels = @Html.Raw(JsonSerializer.Serialize(Model.StatusLabels));
        const statusCounts = @Html.Raw(JsonSerializer.Serialize(Model.StatusCounts));
        const typeLabels = @Html.Raw(JsonSerializer.Serialize(Model.TypeLabels));
        const typeCounts = @Html.Raw(JsonSerializer.Serialize(Model.TypeCounts));
        const branchLabels = @Html.Raw(JsonSerializer.Serialize(Model.BranchLabels));
        const branchCounts = @Html.Raw(JsonSerializer.Serialize(Model.BranchCounts));

        const palette = ['#2563eb', '#16a34a', '#dc2626', '#0ea5e9', '#f59e0b', '#7c3aed', '#14b8a6', '#ef4444'];

        new Chart(document.getElementById('monthlyChart'), {
            type: 'line',
            data: {
                labels: monthlyLabels,
                datasets: [{
                    label: 'الطلبات',
                    data: monthlyCounts,
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37, 99, 235, 0.12)',
                    fill: true,
                    tension: 0.35,
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });

        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: statusLabels,
                datasets: [{ data: statusCounts, backgroundColor: palette.slice(0, statusCounts.length) }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });

        new Chart(document.getElementById('typeChart'), {
            type: 'bar',
            data: {
                labels: typeLabels,
                datasets: [{ label: 'الطلبات', data: typeCounts, backgroundColor: '#14b8a6' }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });

        new Chart(document.getElementById('branchChart'), {
            type: 'bar',
            data: {
                labels: branchLabels,
                datasets: [{ label: 'الطلبات', data: branchCounts, backgroundColor: '#f59e0b' }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });
    </script>
}

