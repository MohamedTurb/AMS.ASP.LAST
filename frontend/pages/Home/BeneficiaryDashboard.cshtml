@model AssistanceManagementSystem.Controllers.BeneficiaryDashboardViewModel
@{
    ViewData["Title"] = "لوحتي";
}

<div class="ams-dashboard-hero">
    <h1 class="ams-dashboard-hero__title">مرحباً، @Model.UserName</h1>
    <p class="ams-dashboard-hero__text">تابع طلباتك وحالتها، وأنشئ طلب مساعدة جديد في أي وقت.</p>
    <div class="ams-flex ams-gap-2">
        <a asp-controller="AssistanceRequests" asp-action="Create" class="ams-btn ams-btn--secondary ams-btn--sm"><i class="fas fa-plus"></i> طلب جديد</a>
        <a asp-controller="AssistanceRequests" asp-action="Index" class="ams-btn ams-btn--secondary ams-btn--sm"><i class="fas fa-list"></i> كل الطلبات</a>
    </div>
</div>

<div class="ams-metrics">
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--brand"><i class="fas fa-file-lines"></i></div>
        <div>
            <div class="ams-metric__label">إجمالي الطلبات</div>
            <div class="ams-metric__value">@Model.TotalRequests</div>
        </div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--warning"><i class="fas fa-clock"></i></div>
        <div>
            <div class="ams-metric__label">قيد المراجعة</div>
            <div class="ams-metric__value">@Model.PendingRequests</div>
        </div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--success"><i class="fas fa-check"></i></div>
        <div>
            <div class="ams-metric__label">معتمدة</div>
            <div class="ams-metric__value">@Model.ApprovedRequests</div>
        </div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--info"><i class="fas fa-flag-checkered"></i></div>
        <div>
            <div class="ams-metric__label">منفّذة</div>
            <div class="ams-metric__value">@Model.ExecutedRequests</div>
        </div>
    </div>
</div>

<div class="ams-card">
    <div class="ams-card__header">
        <div>
            <h2 class="ams-card__title">أحدث الطلبات</h2>
            <p class="ams-card__subtitle">آخر 5 طلبات</p>
        </div>
    </div>
    <div class="ams-card__body p-0">
        @if (Model.RecentRequests.Any())
        {
            <div class="ams-table-wrap">
                <table class="ams-table mb-0">
                    <thead>
                        <tr>
                            <th>النوع</th>
                            <th>المبلغ</th>
                            <th>الحالة</th>
                            <th>التاريخ</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var request in Model.RecentRequests)
                        {
                            <tr>
                                <td>
                                    <div class="ams-fw-semibold">@request.TypeOfAssistance</div>
                                    <small class="ams-text-muted">@request.BeneficiaryName</small>
                                </td>
                                <td>@(request.Amount.HasValue ? $"{request.Amount:N0} جنيه" : "—")</td>
                                <td>@await Html.PartialAsync("_StatusBadge", request.Status)</td>
                                <td>@request.CreatedAt.ToString("yyyy/MM/dd")</td>
                                <td>
                                    <a asp-controller="AssistanceRequests" asp-action="Details" asp-route-id="@request.Id" class="ams-btn ams-btn--ghost ams-btn--sm">
                                        <i class="fas fa-eye"></i> تفاصيل
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            ViewData["EmptyTitle"] = "لا توجد طلبات";
            ViewData["EmptyText"] = "ابدأ بإنشاء أول طلب مساعدة.";
            ViewData["EmptyAction"] = $"<a href=\"{Url.Action("Create", "AssistanceRequests")}\" class=\"ams-btn ams-btn--primary\"><i class=\"fas fa-plus\"></i> طلب جديد</a>";
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
