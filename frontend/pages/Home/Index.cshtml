@model AssistanceManagementSystem.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "لوحة التحكم";
}

<div class="ams-dashboard-hero">
    <h1 class="ams-dashboard-hero__title">مرحباً — نظرة عامة على النظام</h1>
    <p class="ams-dashboard-hero__text">ملخص المستفيدين والطلبات والمنظمات مع متابعة حالات المراجعة والتنفيذ.</p>
    <div class="ams-flex ams-gap-2">
        <a asp-controller="AssistanceRequests" asp-action="Index" class="ams-btn ams-btn--secondary ams-btn--sm">
            <i class="fas fa-file-lines"></i> الطلبات
        </a>
        @if (User.IsInRole("Admin") || User.IsInRole("Branch Manager"))
        {
            <a asp-controller="Reports" asp-action="Analytics" class="ams-btn ams-btn--secondary ams-btn--sm">
                <i class="fas fa-chart-pie"></i> التحليلات
            </a>
        }
    </div>
</div>

<div class="ams-metrics">
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--brand"><i class="fas fa-users"></i></div>
        <div>
            <div class="ams-metric__label">المستفيدون</div>
            <div class="ams-metric__value">@Model.TotalBeneficiaries</div>
            <div class="ams-metric__hint">مسجل في النظام</div>
        </div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--success"><i class="fas fa-file-lines"></i></div>
        <div>
            <div class="ams-metric__label">طلبات المساعدة</div>
            <div class="ams-metric__value">@Model.TotalAssistanceRequests</div>
            <div class="ams-metric__hint">@Model.RequestsThisMonth هذا الشهر</div>
        </div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--warning"><i class="fas fa-tags"></i></div>
        <div>
            <div class="ams-metric__label">التصنيفات</div>
            <div class="ams-metric__value">@Model.TotalAidCategories</div>
        </div>
    </div>
    <div class="ams-metric">
        <div class="ams-metric__icon ams-metric__icon--info"><i class="fas fa-diagram-project"></i></div>
        <div>
            <div class="ams-metric__label">المشاريع</div>
            <div class="ams-metric__value">@Model.TotalProjects</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="ams-card h-100">
            <div class="ams-card__header">
                <div>
                    <h2 class="ams-card__title">توزيع حالات الطلبات</h2>
                    <p class="ams-card__subtitle">معلق · موافق · مرفوض · منفّذ</p>
                </div>
            </div>
            <div class="ams-card__body">
                @{
                    var total = Model.TotalAssistanceRequests;
                    int Pct(int n) => total > 0 ? n * 100 / total : 0;
                }
                <div class="ams-progress-row">
                    <div class="ams-progress-row__head"><span>معلق</span><strong>@Model.PendingRequests</strong></div>
                    <div class="progress"><div class="progress-bar bg-warning" data-progress="@Pct(Model.PendingRequests)"></div></div>
                </div>
                <div class="ams-progress-row">
                    <div class="ams-progress-row__head"><span>موافق عليه</span><strong>@Model.ApprovedRequests</strong></div>
                    <div class="progress"><div class="progress-bar bg-success" data-progress="@Pct(Model.ApprovedRequests)"></div></div>
                </div>
                <div class="ams-progress-row">
                    <div class="ams-progress-row__head"><span>مرفوض</span><strong>@Model.RejectedRequests</strong></div>
                    <div class="progress"><div class="progress-bar bg-danger" data-progress="@Pct(Model.RejectedRequests)"></div></div>
                </div>
                <div class="ams-progress-row ams-mb-0">
                    <div class="ams-progress-row__head"><span>تم التنفيذ</span><strong>@Model.ExecutedRequests</strong></div>
                    <div class="progress"><div class="progress-bar bg-info" data-progress="@Pct(Model.ExecutedRequests)"></div></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="ams-card h-100">
            <div class="ams-card__header">
                <h2 class="ams-card__title">إجراءات سريعة</h2>
            </div>
            <div class="ams-card__body ams-d-grid ams-gap-2">
                <a asp-controller="AssistanceRequests" asp-action="Create" class="ams-btn ams-btn--primary"><i class="fas fa-plus"></i> طلب جديد</a>
                @if (User.IsInRole("Admin") || User.IsInRole("Branch Manager"))
                {
                    <a asp-controller="Organizations" asp-action="Index" class="ams-btn ams-btn--secondary"><i class="fas fa-building"></i> المنظمات</a>
                    <a asp-controller="Projects" asp-action="Index" class="ams-btn ams-btn--secondary"><i class="fas fa-diagram-project"></i> المشاريع</a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Account" asp-action="Index" class="ams-btn ams-btn--secondary"><i class="fas fa-user-gear"></i> المستخدمون</a>
                }
            </div>
        </div>
    </div>
</div>

<div class="ams-card ams-mb-6 mt-4">
    <div class="ams-card__header">
        <div>
            <h2 class="ams-card__title">أحدث الطلبات</h2>
            <p class="ams-card__subtitle">آخر 5 طلبات مسجّلة</p>
        </div>
        <a asp-controller="AssistanceRequests" asp-action="Index" class="ams-btn ams-btn--ghost ams-btn--sm">عرض الكل</a>
    </div>
    <div class="ams-card__body p-0">
        @if (Model.RecentAssistanceRequests.Any())
        {
            <div class="ams-table-wrap">
                <table class="ams-table mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>طالب المساعدة</th>
                            <th>النوع</th>
                            <th>المبلغ</th>
                            <th>الحالة</th>
                            <th>التاريخ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.RecentAssistanceRequests)
                        {
                            <tr>
                                <td class="ams-fw-semibold">@r.Id</td>
                                <td>
                                    <div class="ams-fw-semibold">@r.RequesterName</div>
                                    <small class="ams-text-muted">@r.BeneficiaryName</small>
                                </td>
                                <td>@r.TypeOfAssistance</td>
                                <td>@(r.Amount.HasValue ? $"{r.Amount:N0} جنيه" : "—")</td>
                                <td>@await Html.PartialAsync("_StatusBadge", r.Status)</td>
                                <td>@r.CreatedAt.ToString("yyyy/MM/dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            ViewData["EmptyTitle"] = "لا توجد طلبات حديثة";
            ViewData["EmptyText"] = "ستظهر الطلبات الجديدة هنا.";
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>
