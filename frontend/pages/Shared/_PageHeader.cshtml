@{
    var title = ViewData["PageHeaderTitle"] as string ?? ViewData["Title"] as string ?? "";
    var desc = ViewData["PageHeaderDesc"] as string;
    var eyebrow = ViewData["PageHeaderEyebrow"] as string;
    var icon = ViewData["PageHeaderIcon"] as string;
}
<div class="ams-page-header ams-animate-in">
    @if (!string.IsNullOrWhiteSpace(eyebrow))
    {
        <div class="ams-page-header__eyebrow">@eyebrow</div>
    }
    <div class="ams-page-header__row">
        <div>
            <h1 class="ams-page-header__title">
                @if (!string.IsNullOrWhiteSpace(icon))
                {
                    <i class="@icon ams-text-brand me-2"></i>
                }
                @title
            </h1>
            @if (!string.IsNullOrWhiteSpace(desc))
            {
                <p class="ams-page-header__desc">@desc</p>
            }
        </div>
        @{
            var actions = ViewData["PageHeaderActions"] as string;
            var actionText = ViewData["PageHeaderActionText"] as string;
            var actionUrl = ViewData["PageHeaderActionUrl"] as string;
        }
        @if (!string.IsNullOrWhiteSpace(actions))
        {
            <div class="ams-flex ams-gap-2">@Html.Raw(actions)</div>
        }
        else if (!string.IsNullOrWhiteSpace(actionText) && !string.IsNullOrWhiteSpace(actionUrl))
        {
            <a href="@actionUrl" class="ams-btn ams-btn--primary"><i class="fas fa-plus"></i> @actionText</a>
        }
    </div>
</div>
