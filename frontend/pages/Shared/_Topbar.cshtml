@using AssistanceManagementSystem.Data
@inject ApplicationDbContext _db
@inject Microsoft.AspNetCore.Identity.UserManager<AssistanceManagementSystem.Models.ApplicationUser> _um

<header class="ams-topbar">
    <div class="ams-topbar__start">
        <button type="button" class="ams-btn ams-btn--ghost ams-btn--icon d-lg-none" data-sidebar-toggle aria-label="فتح القائمة">
            <i class="fas fa-bars"></i>
        </button>
        <div class="ams-topbar__search d-none d-md-block">
            <i class="fas fa-search"></i>
            <input type="search" placeholder="بحث سريع..." aria-label="بحث" id="amsGlobalSearch" />
        </div>
    </div>

    <div class="ams-topbar__end">
        <button type="button" class="ams-btn ams-btn--ghost ams-btn--icon" data-theme-toggle aria-label="تبديل الوضع">
            <i class="fas fa-moon"></i>
        </button>

        @if (User.Identity?.IsAuthenticated ?? false)
        {
            var userId = _um.GetUserId(User);
            var unread = _db.Notifications.Count(n => n.UserId == userId && !n.IsRead);
            var latest = _db.Notifications.Where(n => n.UserId == userId).OrderByDescending(n => n.CreatedAt).Take(5).ToList();

            <div class="dropdown">
                <button class="ams-btn ams-btn--ghost ams-btn--icon position-relative" data-bs-toggle="dropdown" aria-label="الإشعارات">
                    <i class="fas fa-bell"></i>
                    @if (unread > 0)
                    {
                        <span class="position-absolute top-0 start-0 translate-middle badge rounded-pill bg-danger" style="font-size:0.65rem">@unread</span>
                    }
                </button>
                <ul class="dropdown-menu dropdown-menu-end ams-dropdown-menu">
                    <li class="px-3 py-2 ams-fw-bold">الإشعارات</li>
                    @if (latest.Any())
                    {
                        @foreach (var n in latest)
                        {
                            <li>
                                <a class="ams-dropdown-item" href="@(!string.IsNullOrEmpty(n.Link) ? n.Link : "#")">
                                    <div class="w-100">
                                        <div>@n.Message</div>
                                        <small class="ams-text-muted">@n.CreatedAt.ToString("yyyy/MM/dd HH:mm")</small>
                                    </div>
                                    @if (!n.IsRead) { <span class="ams-badge ams-badge--pending">جديد</span> }
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="px-3 py-2 ams-text-muted small">لا توجد إشعارات</li>
                    }
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="ams-dropdown-item justify-content-center" asp-controller="Notifications" asp-action="Index">عرض الكل</a></li>
                </ul>
            </div>

            <div class="dropdown">
                <button class="ams-btn ams-btn--secondary ams-btn--sm dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="fas fa-user-circle me-1"></i>
                    @(User.Identity?.Name ?? "حسابي")
                </button>
                <ul class="dropdown-menu dropdown-menu-end ams-dropdown-menu">
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="ams-btn ams-btn--ghost ams-w-full justify-content-start">
                                <i class="fas fa-right-from-bracket me-2"></i> تسجيل الخروج
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        }
        else
        {
            <a class="ams-btn ams-btn--primary ams-btn--sm" asp-controller="Account" asp-action="Login">تسجيل الدخول</a>
        }
    </div>
</header>
