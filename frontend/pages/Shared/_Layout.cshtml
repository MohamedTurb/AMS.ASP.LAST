@{
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
    var useShell = isAuthenticated && !string.Equals(ViewData["LayoutMode"] as string, "minimal", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - نظام إدارة المساعدات</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <script>
        (function () {
            var t = localStorage.getItem("ams-theme");
            if (!t) t = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            document.documentElement.setAttribute("data-theme", t);
        })();
    </script>
</head>
<body class="ams-app">
    @if (useShell)
    {
        <div class="ams-sidebar-backdrop" aria-hidden="true"></div>
        <div class="ams-shell">
            @await Html.PartialAsync("_Sidebar")
            <div class="ams-main">
                @await Html.PartialAsync("_Topbar")
                <div class="ams-content ams-animate-in">
                    @await Html.PartialAsync("_Alerts")
                    @RenderBody()
                </div>
                <footer class="ams-footer">
                    <p class="ams-mb-0">&copy; @DateTime.Now.Year نظام إدارة المساعدات — جميع الحقوق محفوظة</p>
                </footer>
            </div>
        </div>
    }
    else
    {
        @await Html.PartialAsync("_Alerts")
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/modules/theme.js" asp-append-version="true"></script>
    <script src="~/js/modules/sidebar.js" asp-append-version="true"></script>
    <script src="~/js/modules/toast.js" asp-append-version="true"></script>
    <script src="~/js/modules/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
